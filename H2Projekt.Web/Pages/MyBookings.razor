@page "/guest/bookings"
@inherits BasePage
@attribute [Authorize]

@inject ApiClient Api

<PageTitle>Gæst - Mine Bookinger</PageTitle>

@if (WorkContext is not null)
{
    @if (exception is not null)
    {
        <div class="d-flex flex-column gap-2 mb-4">
            @foreach (var error in ApiExceptionHelper.ParseErrors(exception))
            {
                <div class="alert alert-@error.Severity p-2 m-0">@error.Message</div>
            }
        </div>
    }

    <div class="d-flex gap-4">
        <div class="card d-flex flex-column gap-3 p-3 min-w-15rem h-fit">
            <GuestSidebar />
        </div>

        <div class="card p-3 w-100">
            <h4 class="mb-3">
                <i class="bi bi-calendar-range"></i>

                Mine Bookinger
            </h4>

            <div class="d-grid gap-3" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
                @foreach (var booking in WorkContext.Bookings)
                {
                    <BookingCard Booking="booking" OnDelete="PrepareBookingDeletion" />
                }
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModal" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="fs-4 mb-0" id="deleteModalLabel">Slet Booking</h5>

                    <button type="button" class="d-flex justify-content-center align-items-center rounded-2 text-black fs-7 min-w-2rem min-h-2rem w-2rem h-2rem border-0" data-bs-dismiss="modal" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                @if (modalException is not null)
                {
                    <div class="modal-body mt-3 p-0 d-flex flex-column gap-2 mb-3">
                        @foreach (var error in ApiExceptionHelper.ParseErrors(modalException))
                        {
                            <div class="alert alert-@error.Severity p-2 m-0">@error.Message</div>
                        }
                    </div>
                }

                <div class="d-flex gap-3 mt-3">
                    <button type="button" class="btn btn-danger w-50" @onclick="DeleteBooking">
                        <i class="bi bi-trash-fill"></i>

                        Slet Booking
                    </button>

                    <button type="button" class="btn btn-secondary w-50" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i>

                        Annullér
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ApiException? exception;
    private ApiException? modalException;

    private int? bookingToDelete;

    public void PrepareBookingDeletion(BookingWithoutGuestDto booking)
    {
        modalException = null;

        bookingToDelete = booking.Id;
    }

    public async Task DeleteBooking()
    {
        modalException = null;

        if (!bookingToDelete.HasValue || WorkContext is null || !WorkContext.Bookings.Any(b => b.Id == bookingToDelete.Value))
        {
            return;
        }

        try
        {
            await Api.DeleteBookingAsync(bookingToDelete.Value);

            await JS.InvokeVoidAsync("hideModal", "#deleteModal");

            WorkContext.Bookings.Remove(WorkContext.Bookings.First(b => b.Id == bookingToDelete.Value));

            exception = new ApiException(null, 200, $"Booking #{bookingToDelete.Value} er slettet.", null, null);
        }
        catch (ApiException ex)
        {
            modalException = ex;
        }
    }
}