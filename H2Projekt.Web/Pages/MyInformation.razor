@page "/guest/information"
@inherits BasePage
@attribute [Authorize]

@inject ApiClient Api

<PageTitle>Gæst - Mine Oplysninger</PageTitle>

@if (WorkContext is not null)
{
    @if (exception is not null)
    {
        <div class="d-flex flex-column gap-2 mb-4">
            @foreach (var error in ApiExceptionHelper.ParseErrors(exception))
            {
                <div class="alert alert-@error.Severity p-2 m-0">@error.Message</div>
            }
        </div>
    }

    <div class="d-flex gap-4">
        <div class="card d-flex flex-column gap-3 p-3 min-w-15rem h-fit">
            <GuestSidebar />
        </div>

        <div class="card p-3 w-100">
            <h4 class="mb-3">
                <i class="bi bi-person-fill"></i>

                Mine Oplysninger
            </h4>

            @if (!isEditing)
            {
                <div class="mb-2"><strong>Fornavn:</strong> @WorkContext.FirstName</div>
                <div class="mb-2"><strong>Efternavn:</strong> @WorkContext.LastName</div>
                <div><strong>Email:</strong> @WorkContext.Email</div>

                <button class="btn btn-primary mt-3" @onclick="EnableEdit">
                    <i class="bi bi-pencil-fill"></i>

                    Rediger
                </button>
            }
            else
            {
                <GuestFields Model="guestToEdit" />

                <div class="d-flex gap-3 mt-3">
                    <button class="btn btn-success" @onclick="SaveChanges">
                        <i class="bi bi-floppy"></i>

                        Gem
                    </button>

                    <button class="btn btn-secondary" @onclick="CancelEdit">
                        <i class="bi bi-x-lg" />

                        Annullér
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    private ApiException? exception;

    private bool isEditing = false;

    private GuestDto? guestToEdit;

    private void EnableEdit()
    {
        if (WorkContext is null)
        {
            return;
        }

        guestToEdit = new GuestDto
        {
            Id = WorkContext.Id,
            FirstName = WorkContext.FirstName,
            LastName = WorkContext.LastName,
            Email = WorkContext.Email
        };

        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
    }

    private async Task SaveChanges()
    {
        if (WorkContext is null || guestToEdit is null)
        {
            return;
        }

        try
        {
            await Api.UpdateGuestAsync(new UpdateGuestCommand
            {
                Id = guestToEdit.Id,
                FirstName = guestToEdit.FirstName,
                LastName = guestToEdit.LastName,
                Email = guestToEdit.Email
            });

            await AuthService.RefreshAsync();

            isEditing = false;

            guestToEdit = null;

            exception = new ApiException(null, 200, "Oplysninger opdateret.", null, null);
        }
        catch (ApiException ex)
        {
            exception = ex;
        }
    }
}