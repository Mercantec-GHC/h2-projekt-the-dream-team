@page "/admin/manage-guests"
@inherits BasePage
@attribute [Authorize(Roles = "Admin")]

@inject ApiClient Api

<PageTitle>Admin - Gæster</PageTitle>

@if (exception is not null)
{
    <div class="d-flex flex-column gap-2 mb-4">
        @foreach (var error in ApiExceptionHelper.ParseErrors(exception))
        {
            <div class="alert alert-@error.Severity p-2 m-0">@error.Message</div>
        }
    </div>
}

<div id="toolbar" class="d-flex gap-3 align-items-center mb-4">
    <a href="/admin" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>

        Tilbage
    </a>

    <h3 class="heading-gold mb-0">Gæster</h3>
</div>

@if (guests is null)
{
    <p>Henter data...</p>
}
else if (guests.Count == 0)
{
    <em>Ingen gæster fundet.</em>
}
else
{
    <table id="dataTable" class="table table-striped">
        <thead>
            <tr>
                <th width="100">ID</th>
                <th width="100">Fornavn</th>
                <th width="100">Efternavn</th>
                <th width="100">Email</th>
                <th width="1" data-dt-order="disable"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var guest in guests)
            {
                <tr>
                    <td class="align-middle">@guest.Id</td>
                    <td class="align-middle">@guest.FirstName</td>
                    <td class="align-middle">@guest.LastName</td>
                    <td class="align-middle">@guest.Email</td>
                    <td class="align-middle">
                        <div class="d-flex gap-2 w-100 justify-content-end">
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="() => PrepareGuestUpdate(guest)" data-bs-toggle="modal" data-bs-target="#createEditModal">
                                <i class="bi bi-pencil-fill"></i>

                                Rediger
                            </button>

                            <button class="btn btn-sm btn-danger" @onclick="() => PrepareGuestDeletion(guest)" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="bi bi-trash-fill"></i>

                                Slet
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade" id="createEditModal" tabindex="-1" aria-labelledby="createEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-3">
            <div class="d-flex align-items-center justify-content-between">
                <h5 class="fs-4 mb-0" id="createEditModalLabel">Rediger Gæst</h5>

                <button type="button" class="d-flex justify-content-center align-items-center rounded-2 text-black fs-7 min-w-2rem min-h-2rem w-2rem h-2rem border-0" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="modal-body my-3 p-0">
                @if (modalException is not null)
                {
                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var error in ApiExceptionHelper.ParseErrors(modalException))
                        {
                            <div class="alert alert-@error.Severity p-2 m-0">@error.Message</div>
                        }
                    </div>
                }

                @if (guestToEdit is not null)
                {
                    <GuestFields Model="guestToEdit" />
                }
            </div>

            <div class="d-flex gap-3">
                <button type="button" class="btn btn-primary w-50" @onclick="SaveGuest">
                    <i class="bi bi-floppy"></i>

                    Gem Gæst
                </button>

                <button type="button" class="btn btn-secondary w-50" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>

                    Annullér
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModal" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-3">
            <div class="d-flex align-items-center justify-content-between">
                <h5 class="fs-4 mb-0" id="deleteModalLabel">Slet Gæst</h5>

                <button type="button" class="d-flex justify-content-center align-items-center rounded-2 text-black fs-7 min-w-2rem min-h-2rem w-2rem h-2rem border-0" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            @if (modalException is not null)
            {
                <div class="modal-body mt-3 p-0 d-flex flex-column gap-2 mb-3">
                    @foreach (var error in ApiExceptionHelper.ParseErrors(modalException))
                    {
                        <div class="alert alert-@error.Severity p-2 m-0">@error.Message</div>
                    }
                </div>
            }

            <div class="d-flex gap-3 mt-3">
                <button type="button" class="btn btn-danger w-50" @onclick="DeleteGuest">
                    <i class="bi bi-trash-fill"></i>

                    Slet Gæst
                </button>

                <button type="button" class="btn btn-secondary w-50" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>

                    Annullér
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private ApiException? exception;
    private ApiException? modalException;

    private GuestDto? guestToEdit;
    private int? guestToDelete;

    private ICollection<GuestDto> guests;

    protected override async Task OnInitializedAsync()
    {
        guests = await Api.GetAllGuestsAsync();
    }

    public void PrepareGuestUpdate(GuestDto guest)
    {
        modalException = null;

        guestToEdit = new GuestDto()
        {
            Id = guest.Id,
            FirstName = guest.FirstName,
            LastName = guest.LastName,
            Email = guest.Email,
        };
    }

    public void PrepareGuestDeletion(GuestDto guest)
    {
        modalException = null;

        guestToDelete = guest.Id;
    }

    public async Task SaveGuest()
    {
        modalException = null;

        if (guestToEdit is null || guestToEdit.Id == 0)
        {
            return;
        }

        try
        {
            await Api.UpdateGuestAsync(new UpdateGuestCommand()
            {
                Id = guestToEdit.Id,
                FirstName = guestToEdit.FirstName,
                LastName = guestToEdit.LastName,
                Email = guestToEdit.Email,
            });

            var guest = guests.FirstOrDefault(r => r.Id == guestToEdit.Id);

            if (guest is not null)
            {
                guest.FirstName = guestToEdit.FirstName;
                guest.LastName = guestToEdit.LastName;
                guest.Email = guestToEdit.Email;

                if (WorkContext?.Id == guest.Id)
                {
                    await AuthService.RefreshAsync();
                }

                exception = new ApiException(null, 200, $"Gæst \"{guestToEdit.FirstName}\" opdateret.", null, null);
            }

            await JS.InvokeVoidAsync("hideModal", "#createEditModal");

            guestToEdit = null;

            StateHasChanged();
        }
        catch (ApiException ex)
        {
            modalException = ex;
        }
    }

    public async Task DeleteGuest()
    {
        modalException = null;

        if (!guestToDelete.HasValue || !guests.Any(g => g.Id == guestToDelete.Value))
        {
            return;
        }

        try
        {
            await Api.DeleteGuestAsync(guestToDelete.Value);

            await JS.InvokeVoidAsync("hideModal", "#deleteModal");

            guests.Remove(guests.First(g => g.Id == guestToDelete.Value));

            exception = new ApiException(null, 200, $"Gæst #{guestToDelete.Value} er slettet.", null, null);
        }
        catch (ApiException ex)
        {
            modalException = ex;
        }
    }
}