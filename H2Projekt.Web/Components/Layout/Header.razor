@rendermode InteractiveServer

@inject ApiClient Api
@inject GuestService GuestService

<header class="position-fixed top-0 z-1 w-100 d-flex justify-content-between gap-3 p-2 bg-white border-bottom border-2 border-body-secondary h-5rem">
    <div class="d-flex gap-2">
        <NavLink class="btn btn-subtle" href="" Match="NavLinkMatch.All">
            <i class="bi bi-search"></i> Søg
        </NavLink>

        <NavLink class="btn btn-subtle" href="admin">
            <i class="bi bi-gear-fill"</i> Admin
        </NavLink>

        <NavLink class="btn btn-subtle" href="rules">
            <i class="bi bi-list-ol"</i> Regler
        </NavLink>
    </div>


    @if (GuestService.SelectedGuest is null)
    {
        @if (!guests.Any())
        {
            <button class="btn btn-primary" disabled>Vælg Gæst</button>
        }
        else
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal">Vælg Gæst</button>
        }
    }
    else
    {
        <button class="btn btn-subtle" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-person-fill"></i>

            <span>@GuestService.SelectedGuest.FirstName @GuestService.SelectedGuest.LastName</span>
        </button>

        <div class="dropdown-menu dropdown-menu-end px-2">
            <div class="d-flex flex-column gap-2">
                <GuestSidebar />

                <button class="btn btn-subtle text-danger" @onclick="() => GuestService.SelectGuest(null)">
                    <i class="bi bi-box-arrow-right"></i>

                    Log ud
                </button>
            </div>
        </div>
    }
</header>

<div class="modal fade" id="modal" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-3">
            <div class="d-flex align-items-center justify-content-between">
                <h5 class="fs-4 mb-0" id="modalLabel">Vælg Gæst</h5>

                <button type="button" class="d-flex justify-content-center align-items-center rounded-2 text-black fs-7 min-w-2rem min-h-2rem w-2rem h-2rem border-0" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="modal-body my-3 p-0">
                <InputSelect @bind-Value:get="selectedGuestId" @bind-Value:set="SetSelectedGuest" class="form-control">
                    @foreach (var guest in guests)
                    {
                        @if (guest.Id == selectedGuestId)
                        {
                            <option value="@guest.Id" selected>@guest.FirstName @guest.LastName (@guest.Email)</option>

                            continue;
                        }

                        <option value="@guest.Id">@guest.FirstName @guest.LastName (@guest.Email)</option>
                    }
                </InputSelect>
            </div>

            <div class="d-flex gap-3">
                <button type="button" class="btn btn-success w-50" data-bs-dismiss="modal" @onclick="SaveSelectedGuest">
                    <i class="bi bi-floppy"></i>

                    Vælg Gæst
                </button>

                <button type="button" class="btn btn-secondary w-50" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>

                    Annullér
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private ICollection<GuestDto> guests = Array.Empty<GuestDto>();

    private int selectedGuestId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        guests = await Api.GetAllGuestsAsync();

        var selectedGuest = await GuestService.GetGuestFromLocalStorage();

        selectedGuestId = selectedGuest?.Id ?? guests.FirstOrDefault()?.Id ?? 0;

        StateHasChanged();
    }

    private void SetSelectedGuest(int id)
    {
        selectedGuestId = id;
    }

    private async Task SaveSelectedGuest()
    {
        await GuestService.SelectGuest(guests.FirstOrDefault(guest => guest.Id == selectedGuestId));

        StateHasChanged();
    }
}
