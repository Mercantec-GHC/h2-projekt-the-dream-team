@page "/rules"
@rendermode InteractiveServer

@inject ApiClient Api

<PageTitle>Regler</PageTitle>

<h3 class="mb-3">Regler</h3>

@if (rules is null)
{
    <p>Henter regler...</p>
}
else
{
    <div class="card">
        @for (int i = 0; i < rules.Count; i++)
        {
            var rule = rules.ElementAt(i);

            <div>
                <div class="d-flex gap-3 justify-content-center">
                    @if (i > 0)
                    {
                        <hr class="my-auto w-100" />
                    }

                    <h4 class="mt-3 mb-0 text-nowrap">@rule.Title</h4>

                    @if (i > 0)
                    {
                        <hr class="my-auto w-100" />
                    }
                </div>

                <ul>
                    @foreach (var item in rule.Rules)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        }
    </div>
}

@code {
    private ICollection<Rule>? rules;

    protected override async Task OnInitializedAsync()
    {
        rules = await Api.GetRulesAsync();
    }
}