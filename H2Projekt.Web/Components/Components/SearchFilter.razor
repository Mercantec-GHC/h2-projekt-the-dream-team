@rendermode InteractiveServer

@inject ApiClient Api

<div class="d-flex flex-wrap justify-content-center gap-2 w-fit">
    <div class="w-fit">
        <InputDate class="form-control" data-invalid="@isFromDateInvalid" @bind-Value:get="FromDate" @bind-Value:set="SetFromDate" />
    </div>

    <div class="w-fit">
        <InputDate class="form-control" data-invalid="@isToDateInvalid" @bind-Value:get="ToDate" @bind-Value:set="SetToDate" />
    </div>

    <div class="w-fit">
        <div role="button" class="card flex-row h-100 px-2" data-invalid="@isNumberOfGuestsInvalid" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
            <div class="d-flex align-items-center gap-2 px-1">
                <span>@NumberOfAdults @(NumberOfAdults == 1 ? "voksen" : "voksne")</span>

                <span class="text-black-50">•</span>

                <span>@NumberOfChildren @(NumberOfChildren == 1 ? "barn" : "børn")</span>

                @if (TravelingWithPets)
                {
                    <span class="text-black-50">•</span>

                    <span>Med Kæledyr</span>
                }
            </div>
        </div>

        <div class="dropdown-menu dropdown-menu-end px-2">
            <div class="d-flex flex-column gap-3">
                <div>
                    <label class="form-label">Antal voksne</label>

                    <AmountSelector Amount="NumberOfAdults" AmountChanged="SetNumberOfAdults" />
                </div>

                <div>
                    <label class="form-label">Antal børn</label>

                    <AmountSelector Amount="NumberOfChildren" AmountChanged="SetNumberOfChildren" />
                </div>

                <div>
                    <label class="form-label mb-0">Medbringer kæledyr</label>

                    <div class="form-check form-switch form-switch-lg">
                        <input class="form-check-input" type="checkbox" role="button" @bind-value:get="TravelingWithPets" @bind-value:set="SetTravelingWithPets">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
        <button class="btn btn-primary" @onclick="Search" disabled="@isSearchButtonDisabled">
            <i class="bi bi-search"></i>
            Søg
        </button>
    </div>
</div>

@code {
    [Parameter]
    public DateTime FromDate { get; set; }

    [Parameter]
    public EventCallback<DateTime> FromDateChanged { get; set; }

    [Parameter]
    public DateTime ToDate { get; set; }

    [Parameter]
    public EventCallback<DateTime> ToDateChanged { get; set; }

    [Parameter]
    public int NumberOfAdults { get; set; }

    [Parameter]
    public EventCallback<int> NumberOfAdultsChanged { get; set; }

    [Parameter]
    public int NumberOfChildren { get; set; }

    [Parameter]
    public EventCallback<int> NumberOfChildrenChanged { get; set; }

    [Parameter]
    public bool TravelingWithPets { get; set; }

    [Parameter]
    public EventCallback<bool> TravelingWithPetsChanged { get; set; }

    [Parameter]
    public EventCallback<AvailableRoomTypesForStayDto> AvailableRoomTypesForStayChanged { get; set; }

    private async Task SetFromDate(DateTime value)
    {
        FromDate = value;
     
        await FromDateChanged.InvokeAsync(value);
    }

    private async Task SetToDate(DateTime value)
    {
        ToDate = value;

        await ToDateChanged.InvokeAsync(value);
    }

    private async Task SetNumberOfAdults(int value)
    {
        NumberOfAdults = value;
        
        await NumberOfAdultsChanged.InvokeAsync(value);
    }

    private async Task SetNumberOfChildren(int value)
    {
        NumberOfChildren = value;
     
        await NumberOfChildrenChanged.InvokeAsync(value);
    }

    private async Task SetTravelingWithPets(bool value)
    {
        TravelingWithPets = value;
     
        await TravelingWithPetsChanged.InvokeAsync(value);
    }

    private async Task Search()
    {
        try
        {
            var lists = await Api.GetAvailableRoomTypesForStayAsync(FromDate, ToDate, NumberOfAdults, NumberOfChildren, TravelingWithPets);

            if (lists is null)
            {
                return;
            }

            await AvailableRoomTypesForStayChanged.InvokeAsync(lists);
        }
        catch (ApiException) { }
    }

    private bool isFromDateInvalid => ToDate.ToDateOnly() < FromDate.ToDateOnly() || FromDate.ToDateOnly() < DateOnly.FromDateTime(DateTime.Now);

    private bool isToDateInvalid => FromDate.ToDateOnly() > ToDate.ToDateOnly();

    private bool isNumberOfGuestsInvalid => NumberOfAdults <= 0 && NumberOfChildren <= 0;

    private bool isSearchButtonDisabled => isFromDateInvalid || isToDateInvalid || isNumberOfGuestsInvalid;
}
