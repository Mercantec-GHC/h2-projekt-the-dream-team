<div class="card p-3">
    <div class="h-100 d-flex flex-column @(isUnavailable ? "opacity-50 grayscale" : "")">
        <h5 class="fw-bold">@roomType.Name</h5>

        <p class="text-body-secondary">@roomType.Description</p>

        <ul class="p-0 mb-3 mt-auto fs-7">
            <li class="mb-1 text-body-secondary d-flex">
                <span class="w-100">Pris:</span>

                <span class="text-nowrap text-body fw-bold">@roomType.PricePerNight.ToString("C") pr. nat</span>
            </li>

            <li class="text-body-secondary d-flex">
                <span class="w-100">Maks Gæster:</span>

                <span class="text-nowrap text-body fw-bold">@roomType.MaxOccupancy</span>
            </li>

            @* <li class="text-body-secondary d-flex">
                <span class="w-100">Kæledyr tilladt:</span>

                <span class="text-nowrap text-body fw-bold">Ja/nej</span>
            </li> *@
        </ul>

        @if (isUnavailable)
        {
            <button class="btn btn-primary" disabled>Ikke tilgængelig</button>
        }
        else
        {
            <button class="btn btn-primary" @onclick="() => OnBook.InvokeAsync(roomType)">Book nu</button>
        }
    </div>
</div>

@code {
    [Parameter]
    public RoomTypeDto roomType { get; set; }

    [Parameter]
    public bool isUnavailable { get; set; } = false;

    [Parameter]
    public EventCallback<RoomTypeDto> OnBook { get; set; }
}
